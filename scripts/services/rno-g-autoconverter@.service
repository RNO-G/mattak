[Unit]
Description=RNO-G Autoconverter for station %i
PartOf=rno-g-autoconverter.target

[Service]
Type=simple
User=rno-g
WorkingDirectory=/home/rno-g/soft/mattak
ExecStart=/home/rno-g/soft/mattak/scripts/rno-g-autoconverter %i
Restart=always
RestartSec=300
Environment="PATH=/home/rno-g/soft/mattak/install/bin:/usr/local/bin:/usr/bin:/bin"
Environment="LD_LIBRARY_PATH=/home/rno-g/soft/mattak/install/lib:/home/rno-g/soft/librno-g/install/lib"
Environment="PYTHONPATH=/home/rno-g/soft/mattak/py:/home/rno-g/soft/NuRadioMC"

[Install]
WantedBy=rno-g-autoconverter.target
